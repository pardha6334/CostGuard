// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  plan        Plan      @default(TRIAL)
  trialEndsAt DateTime?
  stripeId    String?   @unique
  slackWebhook String?
  platforms   Platform[]
  incidents   Incident[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Platform {
  id                String        @id @default(cuid())
  userId            String
  provider          Provider
  encryptedCreds    String        // AES-256-GCM encrypted JSON
  displayName       String?       // user label e.g. "prod-openai"
  environment       String        @default("production")
  hourlyLimit       Float         @default(200)
  dailyBudget       Float         @default(500)
  monthlyBudget     Float         @default(5000)
  breakerState      BreakerState  @default(CLOSED)
  isActive          Boolean       @default(true)
  autoKill          Boolean       @default(true)
  anomalyDetect     Boolean       @default(true)
  alertEmail        Boolean       @default(true)
  alertSlack        Boolean       @default(true)
  alertWebhook      Boolean       @default(false)
  lastPolledAt      DateTime?
  killSnapshot      String?       // JSON snapshot of pre-kill rate limits (originalLimits)
  lastTriggerType   String?       // HOURLY_LIMIT | DAILY_LIMIT | MONTHLY_LIMIT
  workspaceId       String?       // Anthropic workspace ID (wrkspc_...)
  workspaceName     String?       // Anthropic workspace display name
  killedApiKeyIds   String?       // JSON array of key IDs set inactive on kill
  isAutoDiscovered  Boolean       @default(false)
  parentPlatformId  String?       // for auto-discovered sub-platforms
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  readings          SpendReading[]
  incidents         Incident[]
  logs              Log[]

  @@index([userId, isActive])
  @@index([userId, provider])
}

model SpendReading {
  id          String   @id @default(cuid())
  platformId  String
  amount      Float    // cumulative spend in $
  burnRate    Float    // calculated $/hr
  recordedAt  DateTime @default(now())
  platform    Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@index([platformId, recordedAt])
}

model Incident {
  id              String         @id @default(cuid())
  userId          String
  platformId      String
  triggerType     TriggerType
  spendAtTrigger  Float
  burnRateAtKill  Float
  thresholdLimit  Float
  estimatedSaved  Float          @default(0)
  status          IncidentStatus @default(ACTIVE)
  killedAt        DateTime       @default(now())
  resolvedAt      DateTime?
  resolvedByUserId String?
  durationSecs    Int?
  notes           String?
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform        Platform       @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, killedAt])
  @@index([platformId, killedAt])
}

enum Plan {
  TRIAL
  STARTER
  PRO
  TEAM
}

enum Provider {
  OPENAI
  ANTHROPIC
  AWS
  VERCEL
  SUPABASE
  GCP
  AZURE
  CLOUDFLARE
  TWILIO
  REPLICATE
}

enum BreakerState {
  CLOSED
  OPEN
  HALF_OPEN
}

enum TriggerType {
  HOURLY_LIMIT
  DAILY_LIMIT
  MONTHLY_LIMIT
  SPIKE_DETECTED
  MANUAL
}

enum IncidentStatus {
  ACTIVE
  RESTORING
  RESOLVED
}

model Log {
  id         String       @id @default(cuid())
  platformId String?
  userId     String?
  category   LogCategory
  level      LogLevel
  message    String
  meta       Json?
  createdAt  DateTime     @default(now())

  platform   Platform?    @relation(fields: [platformId], references: [id], onDelete: SetNull)

  @@index([platformId, createdAt])
  @@index([category, createdAt])
  @@index([level, createdAt])
  @@index([createdAt])
  @@index([userId, createdAt])
}

enum LogCategory {
  POLL
  SPEND
  KILL
  RESTORE
  ALERT
  ERROR
  ENGINE
  RATELIMIT
  SYSTEM
}

enum LogLevel {
  INFO
  WARN
  ERROR
  SUCCESS
}
